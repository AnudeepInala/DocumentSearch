# RADAR Document Search System — Environment Configuration
# Copy this file to .env and update values for your environment.

# Python executable (update to match your installation)
PYTHON_BIN=C:\Users\YOUR_USER\AppData\Local\Programs\Python\Python312\python.exe

# Redis connection
REDIS_URL=redis://localhost:6379/1

# OpenSearch
OPENSEARCH_HOST=http://localhost:9200

# Poppler path (required for PDF-to-image OCR)
POPPLER_PATH=C:\path\to\poppler\Library\bin
